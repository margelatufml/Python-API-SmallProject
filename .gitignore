# Ignore Python cache and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore environment folders
env/
venv/
.venv/

# Ignore IDE and editor folders
.idea/
.vscode/

# Ignore database and log files
math_microservice.db
math_microservice.log

# Ignore Docker build artifacts
*.egg-info/
dist/
build/

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore test output
.coverage
htmlcov/

# Ignore other temporary files
*.tmp
*.bak
*.swp
